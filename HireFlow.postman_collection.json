						{
							"listen": "test",
							"script": {
								"exec": [
									"var res = pm.response.json();",
									"if (res.success) {",
									"    pm.collectionVariables.set('accessToken', res.data.accessToken);",
									"    pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Rahul Sharma\",\n    \"email\": \"rahul@example.com\",\n    \"password\": \"password123\",\n    \"role\": \"SEEKER\",\n    \"phone\": \"9876543210\"\n}"
